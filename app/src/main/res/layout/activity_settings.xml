<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:navigationIcon="@drawable/icon_back"
            app:title="设置"
            app:titleTextAppearance="@style/TitleAppearance" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="在线播放音质"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <RadioGroup
            android:id="@+id/radio_quality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/radio_lossless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无损"
                android:checked="true" />
            <RadioButton
                android:id="@+id/radio_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高品"
                android:layout_marginStart="24dp" />
            <RadioButton
                android:id="@+id/radio_standard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="标准"
                android:layout_marginStart="24dp" />
            <RadioButton
                android:id="@+id/radio_fluent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="流畅"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:id="@+id/text_download_path_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="下载保存路径"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/text_download_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:paddingBottom="8dp"
            android:ellipsize="end"
            android:maxLines="2" />

        <Button
            android:id="@+id/btn_choose_download_path"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择文件夹" />

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:id="@+id/text_lyric_retry_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="歌词重试次数"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/radio_lyric_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/radio_retry_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1次"
                android:layout_marginStart="8dp" />
            <RadioButton
                android:id="@+id/radio_retry_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3次"
                android:layout_marginStart="24dp" />
            <RadioButton
                android:id="@+id/radio_retry_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5次"
                android:layout_marginStart="24dp" />
            <RadioButton
                android:id="@+id/radio_retry_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10次"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="蜂窝网络自动降质"
                android:textSize="16sp"
                android:textStyle="bold" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_cellular_auto_lower"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <TextView
            android:id="@+id/text_cellular_quality_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="蜂窝网络音质"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/radio_cellular_quality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/radio_cellular_lossless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无损" />
            <RadioButton
                android:id="@+id/radio_cellular_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高品"
                android:layout_marginStart="24dp" />
            <RadioButton
                android:id="@+id/radio_cellular_standard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="标准"
                android:layout_marginStart="24dp" />
            <RadioButton
                android:id="@+id/radio_cellular_fluent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="流畅"
                android:layout_marginStart="24dp" />
        </RadioGroup>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout> 